# ── Domain ──────────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com
# Dev: "internal" (self-signed). Production: your real email for Let's Encrypt auto-TLS.
CADDY_TLS_MODE=admin@yourdomain.com

# ── Host Ports ───────────────────────────────────────────────────────────────
# All host-side port bindings live here. Internal container ports never change.
# Defaults are set in the 3240-3280 range to avoid conflicts with other projects.
#
PORT_HTTP=3240          # Caddy HTTP  (prod: 80)
PORT_HTTPS=3241         # Caddy HTTPS (prod: 443)
PORT_LIVEKIT=3242       # LiveKit HTTP/WS
PORT_LIVEKIT_RTC=3243   # LiveKit RTC TCP
PORT_TURN=3244          # coturn TURN UDP+TCP
PORT_TURN_TLS=3245      # coturn TURN TLS
PORT_API=3246           # RTCstack REST API
PORT_REDIS=3247         # Redis (expose only for debugging; remove in prod)
PORT_MINIO=3248         # MinIO S3 API
PORT_MINIO_CONSOLE=3249 # MinIO web console
PORT_RTC_UDP_MIN=3250   # LiveKit media UDP range start
PORT_RTC_UDP_MAX=3260   # LiveKit media UDP range end
PORT_TURN_RELAY_MIN=3261  # coturn relay UDP range start
PORT_TURN_RELAY_MAX=3280  # coturn relay UDP range end

# ── RTCstack API ─────────────────────────────────────────────────────────────
API_PORT=3246
# Generate: openssl rand -base64 32
API_KEY=REPLACE_WITH_32_BYTE_RANDOM_BASE64
API_SECRET=REPLACE_WITH_32_BYTE_RANDOM_BASE64
NODE_ENV=production
LOG_LEVEL=info
TOKEN_TTL_SECONDS=21600

# ── LiveKit (shared by API, LiveKit server, Egress) ──────────────────────────
# Generate key: openssl rand -hex 12   secret: openssl rand -base64 40
LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_LIVEKIT_SECRET
LIVEKIT_URL_INTERNAL=http://livekit:7880
LIVEKIT_WSS_URL=wss://yourdomain.com/livekit

# ── LiveKit server ───────────────────────────────────────────────────────────
# Set to the PUBLIC IP of your host machine (not 127.0.0.1)
LIVEKIT_RTC_EXTERNAL_IP=REPLACE_WITH_HOST_PUBLIC_IP
LIVEKIT_REDIS_ADDRESS=redis:6379
LIVEKIT_REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
LIVEKIT_UDP_PORT_MIN=3250
LIVEKIT_UDP_PORT_MAX=3260
LIVEKIT_TURN_ENABLED=false
LIVEKIT_TURN_HOST=yourdomain.com
LIVEKIT_TURN_TLS_PORT=3245
LIVEKIT_TURN_UDP_PORT=3244

# ── LiveKit Egress ───────────────────────────────────────────────────────────
# Internal URL — Egress talks to LiveKit inside Docker, not through the host port
LIVEKIT_URL=ws://livekit:7880
EGRESS_S3_BUCKET=rtcstack-recordings
# Internal URL — Egress talks to MinIO inside Docker
S3_ENDPOINT=http://minio:9000

# ── MinIO ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
MINIO_ROOT_USER=REPLACE_WITH_MINIO_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
# Internal URL — services connect to Redis inside Docker, not through the host port
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@redis:6379

# ── coturn ────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 40
COTURN_STATIC_AUTH_SECRET=REPLACE_WITH_32_BYTE_RANDOM_BASE64
COTURN_REALM=yourdomain.com
COTURN_EXTERNAL_IP=REPLACE_WITH_HOST_PUBLIC_IP

# ── AWS env vars (point at MinIO; swap for real S3/R2 in production) ─────────
AWS_ACCESS_KEY_ID=REPLACE_WITH_MINIO_USER
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_MINIO_PASSWORD
AWS_DEFAULT_REGION=us-east-1

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Leave blank (default) to allow all origins (*).
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=

# ── Speech-to-Text add-ons (optional; requires --profile stt-post / stt-live) ─
# Enable API endpoints:
TRANSCRIPTION_LIVE_ENABLED=false
TRANSCRIPTION_POST_ENABLED=false

# Whisper model: tiny | base | small | medium | large-v3
# tiny/base work on CPU. medium/large need a GPU.
WHISPER_MODEL=base
# cpu | cuda  — use cuda only with nvidia-container-toolkit installed
WHISPER_DEVICE=cpu
# int8 (CPU) | float16 (GPU)
WHISPER_COMPUTE_TYPE=int8

# Language for transcription (ISO 639-1 code, e.g. en, fr, de) or "auto"
STT_LANGUAGE=en
# Silence duration (seconds) after which a speech chunk is sent to Whisper
# Note: UI MERGE_THRESHOLD_MS should be >= PAUSE_THRESHOLD_SECONDS*1000 + ~2000ms (Whisper latency)
PAUSE_THRESHOLD_SECONDS=1.5
# Shorter pause (seconds): flush early only if the previous chunk ended with terminal punctuation
SHORT_PAUSE_SECONDS=0.3
# Hard ceiling (seconds) for a single Whisper chunk regardless of speech activity
MAX_CHUNK_SECONDS=30.0
# 16-bit PCM RMS level above which a frame is counted as speech (tune per mic/environment)
# If transcription never triggers, lower this value first (try 100)
SPEECH_RMS_THRESHOLD=200
# Max simultaneous Whisper requests per room (prevents queue pile-up with multiple speakers)
WHISPER_MAX_CONCURRENT=2
# Optional: comma-separated phrases to treat as silence hallucinations and drop
# WHISPER_FILTER_PHRASES=

# Internal URL for services to reach Whisper (change if running STT on separate machine)
WHISPER_URL=http://whisper:8080
# Host port to expose Whisper REST API (useful for debugging or remote access)
PORT_WHISPER=3281

S3_BUCKET_TRANSCRIPTS=rtcstack-transcripts
