# RTCstack — STT standalone machine environment
# Copy to .env.stt and fill in values pointing at your main stack machine.
#
# SECURITY: Redis and MinIO must be reachable over a private/encrypted channel.
# Use WireGuard, Tailscale, or an SSH tunnel — never expose bare Redis/MinIO publicly.
#
# See docker-compose.stt.yml for deployment instructions.

# ── LiveKit (for the live STT agent) ─────────────────────────────────────────
# Same values as your main .env
LIVEKIT_URL=ws://MAIN_HOST_IP_OR_HOSTNAME:3242
LIVEKIT_API_KEY=REPLACE_WITH_LIVEKIT_KEY
LIVEKIT_API_SECRET=REPLACE_WITH_LIVEKIT_SECRET

# ── Redis (must be reachable from this machine) ───────────────────────────────
# If using SSH tunnel: ssh -L 6379:localhost:6379 user@main-host
# Then use: redis://:PASSWORD@127.0.0.1:6379
REDIS_URL=redis://:REPLACE_WITH_REDIS_PASSWORD@MAIN_HOST_IP_OR_HOSTNAME:3247

# ── MinIO (must be reachable from this machine) ───────────────────────────────
MINIO_ENDPOINT=MAIN_HOST_IP_OR_HOSTNAME
MINIO_PORT=3248
MINIO_USE_SSL=false
AWS_ACCESS_KEY_ID=REPLACE_WITH_MINIO_USER
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_MINIO_PASSWORD
MINIO_BUCKET=rtcstack-recordings

# ── Whisper model settings ────────────────────────────────────────────────────
# CPU (no GPU):
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# GPU (NVIDIA, 8GB+ VRAM):
# WHISPER_MODEL=large-v3
# WHISPER_DEVICE=cuda
# WHISPER_COMPUTE_TYPE=float16

# ── STT behaviour ─────────────────────────────────────────────────────────────
STT_LANGUAGE=en          # ISO 639-1 language code, or "auto" for detection
STT_CHUNK_SECONDS=4      # Audio chunk size for live STT (smaller = lower latency, more requests)

# ── Host port for Whisper REST API ───────────────────────────────────────────
PORT_WHISPER=3281
